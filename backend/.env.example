# Wompi
WOMPI_PUBLIC_KEY=pub_test_your_public_key
WOMPI_PRIVATE_KEY=prv_test_your_private_key
WOMPI_INTEGRITY_SECRET=test_integrity_your_secret
WOMPI_URL=https://sandbox.wompi.co/v1

# Public backend URL used in Wompi redirect
BACKEND_BASE_URL=http://localhost:8000

# PostgreSQL (when configured, backend stores orders/events in database)
# Example: postgresql+psycopg2://user:password@localhost:5432/universo_mercantil
DATABASE_URL=

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Flask runtime
FLASK_DEBUG=false
PORT=8000
LOG_LEVEL=INFO

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@example.com

# Billing notification targets
FACTURACION_EMAIL_TO=billing@example.com
FACTURACION_EMAIL_CC=
